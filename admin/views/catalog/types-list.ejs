<%- include('../partials/header') %>
<div style="display:flex; justify-content:space-between; align-items:center;">
  <h1>Types</h1>
  <a href="/types/new" role="button">+ New Type</a>
</div>

<table>
  <thead>
    <tr><th>Name</th><th>Slug</th><th>Models</th></tr>
  </thead>
  <tbody>
    <% for (const t of types) { %>
    <tr>
      <td><a href="/types/<%= t.id %>"><%= t.name %></a></td>
      <td><%= t.slug || '' %></td>
      <td><%= t.model_count %></td>
    </tr>
    <% } %>
    <% if (types.length === 0) { %><tr><td colspan="3">No types</td></tr><% } %>
  </tbody>
</table>
<%- include('../partials/footer') %>
