<%- include('../partials/header') %>
<div style="display:flex; justify-content:space-between; align-items:center;">
  <h1>Equipment</h1>
  <a href="/equipment/new" role="button">+ New Equipment</a>
</div>

<form class="filter-bar">
  <select name="category" hx-get="/equipment" hx-target="#equip-tbody" hx-include="closest form" hx-trigger="change" hx-push-url="true">
    <option value="">All Categories</option>
    <% for (const cat of categories) { %>
      <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
    <% } %>
  </select>
  <input type="search" name="q" placeholder="Search equipment..." value="<%= filters.q || '' %>"
    hx-get="/equipment" hx-target="#equip-tbody" hx-include="closest form"
    hx-trigger="keyup changed delay:300ms" hx-push-url="true">
</form>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Abbreviation</th>
      <th>Category</th>
      <th>Typical Points</th>
    </tr>
  </thead>
  <tbody id="equip-tbody">
    <%- include('_rows') %>
  </tbody>
</table>
<%- include('../partials/footer') %>
