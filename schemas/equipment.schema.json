{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidekick.com/schemas/equipment.schema.json",
  "type": "object",
  "required": ["id", "name", "category", "description", "aliases", "concept"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "full_name": { "type": "string" },
    "abbreviation": { "type": "string" },
    "category": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "haystack": { "type": "string" },
    "brick": { "type": "string" },
    "aliases": {
      "type": "object",
      "required": ["common"],
      "properties": {
        "common": { "type": "array", "items": { "type": "string" } },
        "abbreviated": { "type": "array", "items": { "type": "string" } },
        "verbose": { "type": "array", "items": { "type": "string" } },
        "misspellings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "subtypes": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "aliases": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "typical_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "concept": {
      "type": "object",
      "required": ["kind", "synonyms"],
      "properties": {
        "kind": { "const": "equipment" },
        "system": { "type": "string" },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
