{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidekick.com/schemas/graph.schema.json",
  "type": "object",
  "required": ["version", "lastUpdated", "nodes", "edges", "adjacency"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["point", "equipment", "template"] },
          "name": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "rel", "to", "source"],
        "properties": {
          "from": { "type": "string" },
          "rel": { "type": "string" },
          "to": { "type": "string" },
          "source": { "type": "string", "enum": ["point-related", "template"] }
        },
        "additionalProperties": false
      }
    },
    "adjacency": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["to", "rel"],
          "properties": {
            "to": { "type": "string" },
            "rel": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "additionalProperties": false
}
