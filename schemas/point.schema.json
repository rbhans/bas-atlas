{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidekick.com/schemas/point.schema.json",
  "type": "object",
  "required": ["concept", "aliases"],
  "properties": {
    "concept": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "description",
        "kind",
        "type",
        "unitsNormalized",
        "tags"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "subcategory": { "type": "string" },
        "description": { "type": "string", "minLength": 1 },
        "haystack": { "type": "string" },
        "brick": { "type": "string" },
        "unit": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "point_function": { "type": "string" },
        "states": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          }
        },
        "kind": { "const": "point" },
        "type": {
          "type": "string",
          "enum": ["sensor", "command", "setpoint", "alarm", "status", "calc"]
        },
        "unitsNormalized": {
          "type": "array",
          "items": { "type": "string" }
        },
        "statesNormalized": {
          "type": "object",
          "properties": {
            "0": { "type": "string" },
            "1": { "type": "string" }
          },
          "additionalProperties": false
        },
        "tags": {
          "type": "object",
          "required": ["haystack"],
          "properties": {
            "haystack": {
              "type": "array",
              "items": { "type": "string" }
            },
            "brick": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "aliases": {
      "type": "object",
      "required": ["common", "variants"],
      "properties": {
        "common": {
          "type": "array",
          "items": { "type": "string" }
        },
        "abbreviated": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verbose": {
          "type": "array",
          "items": { "type": "string" }
        },
        "misspellings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "type"],
            "properties": {
              "value": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["abbrev", "expanded", "misspelling", "format", "vendor"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
