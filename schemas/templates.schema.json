{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidekick.com/schemas/templates.schema.json",
  "type": "object",
  "required": ["version", "lastUpdated", "templates"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "equipmentTypeId",
          "version",
          "requiredPoints",
          "optionalPoints",
          "recommendedPoints",
          "relationships",
          "notes"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "equipmentTypeId": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "requiredPoints": { "type": "array", "items": { "type": "string" } },
          "optionalPoints": { "type": "array", "items": { "type": "string" } },
          "recommendedPoints": { "type": "array", "items": { "type": "string" } },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "rel", "to"],
              "properties": {
                "from": { "type": "string" },
                "rel": {
                  "type": "string",
                  "enum": ["feeds", "controls", "depends_on", "measures", "commands"]
                },
                "to": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
