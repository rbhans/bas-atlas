{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidekick.com/schemas/index.schema.json",
  "type": "object",
  "required": ["version", "lastUpdated", "totalPoints", "totalEquipment", "points", "equipment"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "totalPoints": { "type": "integer", "minimum": 0 },
    "totalEquipment": { "type": "integer", "minimum": 0 },
    "points": {
      "type": "array",
      "items": { "type": "object" }
    },
    "equipment": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
