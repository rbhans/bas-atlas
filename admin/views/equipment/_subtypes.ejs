<% for (const st of subtypes) { %>
<article style="padding:0.75rem; margin-bottom:0.5rem;">
  <div style="display:flex; justify-content:space-between; align-items:center;">
    <div>
      <strong><%= st.subtype_name %></strong> <small class="muted">(<%= st.subtype_id %>)</small>
      <% if (st.description) { %><br><small><%= st.description %></small><% } %>
      <% const stAliases = subtypeAliases.filter(a => a.subtype_id === st.subtype_id); %>
      <% if (stAliases.length > 0) { %>
        <br><small>Aliases: <%= stAliases.map(a => a.alias).join(', ') %></small>
      <% } %>
    </div>
    <button class="outline contrast" style="padding:0.2rem 0.5rem; margin:0;"
            hx-delete="/equipment/<%= equip.id %>/subtypes/<%= st.subtype_id %>"
            hx-target="#equip-subtypes"
            hx-confirm="Delete subtype '<%= st.subtype_name %>'?">&times;</button>
  </div>
</article>
<% } %>
<% if (subtypes.length === 0) { %><p><small class="muted">No subtypes</small></p><% } %>

<form class="inline-form" hx-post="/equipment/<%= equip.id %>/subtypes" hx-target="#equip-subtypes">
  <input type="text" name="subtype_id" placeholder="ID..." required style="width:150px;">
  <input type="text" name="subtype_name" placeholder="Name..." required>
  <input type="text" name="description" placeholder="Description (optional)">
  <button type="submit">Add</button>
</form>
