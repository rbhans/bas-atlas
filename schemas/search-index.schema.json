{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidekick.com/schemas/search-index.schema.json",
  "type": "object",
  "required": ["version", "entries"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "tokens", "weightedTokens"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["point", "equipment"] },
          "name": { "type": "string", "minLength": 1 },
          "tokens": {
            "type": "array",
            "items": { "type": "string" }
          },
          "weightedTokens": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["token", "weight", "source"],
              "properties": {
                "token": { "type": "string" },
                "weight": { "type": "number" },
                "source": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "ngrams": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
